APP_NAME="ClipTrend AI"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cliptrend
DB_USERNAME=cliptrend
DB_PASSWORD=change-me

SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379

FILESYSTEM_DISK=s3
MEDIA_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

VIDEO_MAX_UPLOAD_MB=4096
FFMPEG_BIN=/usr/bin/ffmpeg
FFPROBE_BIN=/usr/bin/ffprobe
RENDER_PRESET=medium
RENDER_CRF=21
RENDER_TIMEOUT=7200
DEFAULT_CROP_MODE=fit_blur
SUBTITLE_FONT_FILE=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
WATERMARK_TEXT=YourBrand

AI_PROVIDER=real
TRANSCRIPTION_LANGUAGE=id
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=900
OPENAI_MAX_ANALYSIS_CHARS=16000

TREND_PROVIDER=youtube
YOUTUBE_DATA_API_KEY=
YOUTUBE_INGESTION_ENABLED=false
YTDLP_BIN=/usr/local/bin/yt-dlp

# V7 real media normalization
NORMALIZE_ON_UPLOAD=true
NORMALIZE_TIMEOUT=3600
NORMALIZE_PRESET=veryfast
NORMALIZE_CRF=20
NORMALIZED_PREFIX=projects
